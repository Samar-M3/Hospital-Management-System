<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
    styleClass="root-pane"
    stylesheets="@style.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="controller.LoginController">

    <HBox spacing="0">
        
        <!-- ── Left branding panel ── -->
        <VBox
            alignment="CENTER"
            prefWidth="360"
            spacing="12.0"
            VBox.vgrow="ALWAYS"
            styleClass="brand-panel">

            <Label text="🏥" styleClass="brand-icon" />
            <Label text="SHMS" styleClass="brand-title" />
            <Label text="Smart Hospital" styleClass="brand-sub" />
            <Label text="Management System" styleClass="brand-sub" />
            
            <VBox spacing="4" alignment="CENTER" styleClass="brand-features">
                <Label text="• Easy Appointment Booking" styleClass="brand-feature"/>
                <Label text="• Quick Token Generation" styleClass="brand-feature"/>
                <Label text="• Real-time Queue Updates" styleClass="brand-feature"/>
            </VBox>
        </VBox>

        <!-- ── Right form panel ── -->
        <VBox
            alignment="CENTER"
            spacing="16.0"
            HBox.hgrow="ALWAYS"
            VBox.vgrow="ALWAYS"
            styleClass="form-panel">

            <padding>
                <Insets topRightBottomLeft="48.0" />
            </padding>

            <Label text="Welcome Back" styleClass="form-title" />
            <Label text="Sign in to your account" styleClass="form-subtitle" />
            <Label text="Your role is detected automatically."
                   styleClass="hint-label" />

            <!-- ── Email field ── -->
            <VBox spacing="6.0">
                <Label text="Email" styleClass="field-label" />
                <TextField
                    fx:id="tfEmail"
                    promptText="Enter your email"
                    styleClass="input-field" />
            </VBox>

            <!-- ── Password field ── -->
            <VBox spacing="6.0">
                <Label text="Password" styleClass="field-label" />
                <PasswordField
                    fx:id="pfPassword"
                    promptText="Enter your password"
                    styleClass="input-field" />
            </VBox>

            <!-- ── Error label ── -->
            <Label
                fx:id="lblError"
                text=""
                styleClass="error-label"
                wrapText="true"
                maxWidth="340.0" />

            <!-- ── Login button ── -->
            <Button
                text="Sign In"
                onAction="#handleLogin"
                maxWidth="Infinity"
                styleClass="btn-primary" />

            <!-- ── Register link ── -->
            <HBox alignment="CENTER" spacing="4.0">
                <Label text="Don't have an account?" styleClass="hint-label" />
                <Hyperlink
                    text="Register"
                    onAction="#goToRegister"
                    styleClass="link" />
            </HBox>

        </VBox>
    </HBox>

</StackPane>
