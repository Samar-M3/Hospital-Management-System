<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.layout.AnchorPane?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="controller.RegisterController"
           prefWidth="900" prefHeight="650"
           styleClass="root-pane"
           xmlns="http://javafx.com/javafx/21">

    <HBox spacing="0">
        <!-- Left branding panel -->
        <VBox styleClass="brand-panel" prefWidth="340" alignment="CENTER" VBox.vgrow="ALWAYS">
            <VBox.margin><Insets top="60" left="50" right="40" bottom="40"/></VBox.margin>
            <VBox spacing="16" alignment="CENTER" VBox.vgrow="ALWAYS">
                <StackPane>
                    <Circle radius="36" styleClass="logo-circle"/>
                    <Text text="+" styleClass="logo-plus"/>
                </StackPane>
                <VBox spacing="8" alignment="CENTER">
                    <Label text="SHMS" styleClass="brand-title"/>
                    <Label text="Smart Hospital" styleClass="brand-sub"/>
                    <Label text="Management System" styleClass="brand-sub"/>
                </VBox>
                <Region VBox.vgrow="ALWAYS"/>
                <VBox spacing="4" alignment="CENTER">
                    <Label text="Join our healthcare platform" styleClass="brand-tagline"/>
                    <Label text="and book appointments today." styleClass="brand-tagline"/>
                </VBox>
            </VBox>
        </VBox>

        <!-- Right form panel -->
        <ScrollPane fitToWidth="true" styleClass="scroll-transparent" HBox.hgrow="ALWAYS"
                     AnchorPane.bottomAnchor="0" AnchorPane.topAnchor="0">
            <VBox styleClass="form-panel" spacing="0" alignment="CENTER" minHeight="650" VBox.vgrow="ALWAYS">
                <VBox.margin><Insets top="40" left="60" right="60" bottom="40"/></VBox.margin>

                <Label text="Create account" styleClass="form-title"/>
                <Label text="Register as a new patient" styleClass="form-subtitle"/>

                <!-- Row 1: Name + Gender -->
                <HBox spacing="16" maxWidth="460" prefWidth="460">
                    <HBox.margin><Insets top="28"/></HBox.margin>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Full name" styleClass="field-label"/>
                        <TextField fx:id="tfName" promptText="John Doe" styleClass="field-input"/>
                    </VBox>
                    <VBox spacing="6" prefWidth="130">
                        <Label text="Gender" styleClass="field-label"/>
                        <ComboBox fx:id="cbGender" prefWidth="130" styleClass="field-combo" promptText="Select"/>
                    </VBox>
                </HBox>

                <!-- Row 2: DOB + Phone -->
                <HBox spacing="16" maxWidth="460" prefWidth="460">
                    <HBox.margin><Insets top="14"/></HBox.margin>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Date of birth" styleClass="field-label"/>
                        <DatePicker fx:id="dpDob" styleClass="field-input" prefWidth="200"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Phone number" styleClass="field-label"/>
                        <TextField fx:id="tfPhone" promptText="+44 7700 000000" styleClass="field-input"/>
                    </VBox>
                </HBox>

                <!-- Email -->
                <VBox spacing="6" maxWidth="460" prefWidth="460">
                    <VBox.margin><Insets top="14"/></VBox.margin>
                    <Label text="Email address" styleClass="field-label"/>
                    <TextField fx:id="tfEmail" promptText="you@example.com" styleClass="field-input"/>
                </VBox>

                <!-- Password -->
                <VBox spacing="6" maxWidth="460" prefWidth="460">
                    <VBox.margin><Insets top="14"/></VBox.margin>
                    <Label text="Password" styleClass="field-label"/>
                    <PasswordField fx:id="pfPassword" promptText="Min. 8 characters" styleClass="field-input"/>
                </VBox>

                <!-- Confirm Password -->
                <VBox spacing="6" maxWidth="460" prefWidth="460">
                    <VBox.margin><Insets top="14"/></VBox.margin>
                    <Label text="Confirm password" styleClass="field-label"/>
                    <PasswordField fx:id="pfConfirm" promptText="Re-enter password" styleClass="field-input"/>
                </VBox>

                <!-- Message -->
                <Label fx:id="lblMessage" styleClass="error-label" maxWidth="460" wrapText="true">
                    <VBox.margin><Insets top="10"/></VBox.margin>
                </Label>

                <!-- Register button -->
                <Button text="Create Account" onAction="#handleRegister"
                        styleClass="btn-primary" prefWidth="460" prefHeight="46">
                    <VBox.margin><Insets top="20"/></VBox.margin>
                </Button>

                <!-- Back to login -->
                <HBox alignment="CENTER" spacing="6">
                    <VBox.margin><Insets top="18"/></VBox.margin>
                    <Label text="Already have an account?" styleClass="register-prompt"/>
                    <Hyperlink text="Sign in" onAction="#goToLogin" styleClass="register-link"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </HBox>
</StackPane>